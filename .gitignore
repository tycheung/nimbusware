# Byte-compiled / optimized
# Do not run `git rm -r --cached .` to "clean" the index: that un-stages everything,
# including this file, until you `git add` again. Prefer removing only cache paths.
# Explicit **/ so every nested __pycache__ and .pyc is ignored (same as Git default rules,
# but obvious to humans and tools that only understand simple globs).
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
ENV/
env/

# Packaging / install metadata
.Python
build/
develop-eggs/
dist/
# PyInstaller spec if accidentally regenerated at repo root (canonical: scripts/NimbuswareLauncher.spec)
/NimbuswareLauncher.spec
# Rare stray single-character junk at repo root (broken UPX/tooling redirects)
/[0-9]
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-wheel-metadata/

# Test / coverage / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.coverage
.coverage.*
.ci_coverage.json
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/
nosetests.xml

# Environment and local secrets (never commit real credentials)
.env
.env.*
!.env.example

# Streamlit local secrets (repo may ship `.streamlit/config.toml`)
.streamlit/secrets.toml

# Logs and local scratch
*.log
logs/
.cache/
# Operator chat transcripts (fo150; local only)
.cache/nimbusware_chat/
# Explicit .cache artifacts (redundant with .cache/ but documents intent)
.cache/hermes_scraper/
.cache/run_dispatch_worker_heartbeat.json
.cache/fleet_ollama_sli.json

# Agent / editor scratch at repo root (not product code)
/_patch*.txt
/_patch_*.txt
/_scraper_patch_*.txt
/_recovered_*.txt

# Derived FAISS / memory indexes (rebuild via scripts or API)
configs/memory/index/
configs/memory/fleet/
configs/bundles/index/

# Local credentials (extra guard alongside .env)
*.pem
*.key
credentials.json
secrets.json

# Merge / editor noise
*.orig
*.rej
*~

# Nimbusware planning docs (normative contract may stay out of repo)
hermes-orchestrator-local-plan.md
PLAN_GAP.md

# Hermes agent local run artifacts (integration adapter workspaces, etc.)
.hermes/

# Cursor workspace (loops, plans, artifacts — local only)
.cursor/
.cursorignore

# OS noise
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors (uncomment if you do not commit any workspace settings)
# .vscode/
# .idea/

# Jupyter
.ipynb_checkpoints/

# Local databases / scratch SQLite
*.sqlite
*.sqlite3
*.db-journal

# Root ignore files must stay tracked (safety if a future broad rule overlaps).
!/.gitignore
