# Diagnose/learn runtime docs (per-workspace; see diagnose_learn.py, ADR 012)
docs/learnings/
**/docs/learnings/

# Nimbusware agent local run artifacts (integration adapter workspaces, etc.)
.nimbusware/

# Cursor workspace (loops, plans, artifacts — local only)
.cursor/
.cursorignore

# OS noise
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors (uncomment if you do not commit any workspace settings)
# .vscode/
# .idea/

# Jupyter
.ipynb_checkpoints/

# Local databases / scratch SQLite
*.sqlite
*.sqlite3
*.db-journal

# Root ignore files must stay tracked (safety if a future broad rule overlaps).
!/.gitignore
