# Byte-compiled / optimized
# Do not run `git rm -r --cached .` to "clean" the index: that un-stages everything,
# including this file, until you `git add` again. Prefer removing only cache paths.
# Explicit **/ so every nested __pycache__ and .pyc is ignored (same as Git default rules,
# but obvious to humans and tools that only understand simple globs).
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
ENV/
env/

# Packaging / install metadata (repo-root setuptools/pip dirs only — not package src/lib/)
.Python
/build/
/develop-eggs/
/dist/
/downloads/
/eggs/
/.eggs/
/lib/
/lib64/
/parts/
/sdist/
/var/
/wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-wheel-metadata/
# PyInstaller spec if accidentally regenerated at repo root (canonical: scripts/NimbuswareLauncher.spec)
/NimbuswareLauncher.spec
# Rare stray single-character junk at repo root (broken UPX/tooling redirects)
/[0-9]

# JavaScript / web UI tooling
node_modules/
**/.vite/
*.tsbuildinfo
# Playwright (tests/e2e/web)
tests/e2e/web/test-results/
packages/nimbusware_maker_web/test-results/
extensions/**/node_modules/
extensions/**/package-lock.json
tests/e2e/web/playwright-report/
tests/e2e/web/blob-report/
# Maven build output from local JVM patch fixture verification
tests/fixtures/repos/tiny_jvm_app/target/

# Environment and local secrets (never commit real credentials)
.env
.env.*
!.env.example

# Retired Streamlit operator trees — do not re-commit if recreated locally
packages/nimbusware_maker/ui/
packages/nimbusware_console/pages/
.streamlit/

# Logs and local scratch
*.log
logs/
.cache/

# Python linter / test tool caches (local only)
.mypy_cache/
.pytest_cache/
.ruff_cache/

# CI scratch (local ci_check / coverage floors)
.ci_coverage.json
.ci_*.log

# Python test coverage (pytest-cov / coverage.py — local only)
.coverage
.coverage.*
htmlcov/
coverage.xml

# Operator chat transcripts (fo150; local only)
.cache/nimbusware_chat/
# Explicit .cache artifacts (redundant with .cache/ but documents intent)
.cache/nimbusware_scraper/
