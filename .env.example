# Copy to `.env` at the repo root. Loaded automatically by API, console, CLIs, and pytest.
# Shell variables already set are not overwritten.

HERMES_REPO_ROOT=
HERMES_SKIP_PREFLIGHT=1
HERMES_DATABASE_URL=postgresql://hermes:hermes@127.0.0.1:5432/hermes

# Postgres superuser password from the installer wizard (install script prompts if wrong/missing).
# HERMES_POSTGRES_SUPERPASSWORD=

PORT=8000
HERMES_API_BASE=http://127.0.0.1:8000/v1

# Enable Ollama/LLM stages when workflow YAML allows (plan, critiques, agent evaluator, etc.).
# Set automatically by scripts/install_hermes.py when Ollama setup succeeds.
# HERMES_USE_LLM=1

# Optional: override Ollama API URL (default http://127.0.0.1:11434)
# OLLAMA_HOST=http://127.0.0.1:11434

# Secret for admin API routes; send header X-Hermes-Admin-Token: <value>
# HERMES_ADMIN_TOKEN=
