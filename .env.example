# Copy to `.env` at the Nimbusware repo root. Loaded automatically by API, console, CLIs, and pytest.
# NIMBUSWARE_* — platform (database, API base, admin token, repo root, product edition).
# HERMES_* — Hermes agent runtime only (LLM, critics, slice, scanners, preflight).
# Shell variables already set are not overwritten.

NIMBUSWARE_REPO_ROOT=
# Product edition: individual (default, local-first) | enterprise (Lane D modules)
# NIMBUSWARE_EDITION=individual
HERMES_SKIP_PREFLIGHT=1
NIMBUSWARE_DATABASE_URL=postgresql://nimbusware:nimbusware@127.0.0.1:5432/nimbusware

# Postgres superuser password from the installer wizard (install script prompts if wrong/missing).
# NIMBUSWARE_POSTGRES_SUPERPASSWORD=

PORT=8000
NIMBUSWARE_API_BASE=http://127.0.0.1:8000/v1

# Enable Ollama/LLM stages when workflow YAML allows (plan, critiques, agent evaluator, etc.).
# Set automatically by scripts/install_nimbusware.py when Ollama setup succeeds.
# HERMES_USE_LLM=1

# Optional: override Ollama API URL (default http://127.0.0.1:11434)
# OLLAMA_HOST=http://127.0.0.1:11434

# Secret for admin API routes; send header X-Nimbusware-Admin-Token: <value>
# Replace before production — search: nimbusware-dev-admin-token-SEARCH_AND_REPLACE_BEFORE_PROD
NIMBUSWARE_ADMIN_TOKEN=nimbusware-dev-admin-token-SEARCH_AND_REPLACE_BEFORE_PROD

# Enterprise Maker user key (maker_user scope). Individual edition: leave unset.
# NIMBUSWARE_API_KEY=

# Cross-console deep links (desktop defaults)
# NIMBUSWARE_MAKER_URL=http://127.0.0.1:8501
# NIMBUSWARE_ADMIN_CONSOLE_URL=http://127.0.0.1:8502
