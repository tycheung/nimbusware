# Copy to `.env` at the Nimbusware repo root. Loaded automatically by API, console, CLIs, and pytest.
# Nomenclature: Nimbusware = this codebase and agent runtime (local-first platform).
# Install-only (secrets/infra): NIMBUSWARE_DATABASE_URL, NIMBUSWARE_REPO_ROOT, NIMBUSWARE_ADMIN_TOKEN, PORT, …
# System/user/run tunables: Maker Settings + Admin Console — see docs/operator-settings.md
# Shell variables already set are not overwritten.

NIMBUSWARE_REPO_ROOT=
# Desktop / launcher UI: web (default; opens /v1/maker/app or /v1/admin/app via pywebview)
# NIMBUSWARE_UI_BACKEND=web
# Maker projects bind runs to project.workspace_path (POST/PATCH /v1/projects), not a separate env var.
# Product edition: individual (default, local-first) | enterprise (Lane D modules)
# NIMBUSWARE_EDITION=individual
# Dev: NIMBUSWARE_SKIP_PREFLIGHT=1 (or Admin Console → system)
# Optional theater digest: NIMBUSWARE_THEATER_LLM_SUMMARY=1
# Optional theater summary model: NIMBUSWARE_THEATER_LLM_MODEL=llama3.2
# Optional human-fidelity axe rules: NIMBUSWARE_AXE_ENABLED=1
# Agent tools safety (defaults): NIMBUSWARE_FILESYSTEM_JAIL=1  NIMBUSWARE_SANDBOX_BACKEND=none
# Individual v1 docker sandbox: NIMBUSWARE_SANDBOX_BACKEND=docker  (requires local Docker CLI)
# NIMBUSWARE_SANDBOX_DOCKER_IMAGE=python:3.11-slim
# Fleet sandboxes: NIMBUSWARE_SANDBOX_BACKEND=kubernetes|e2b  NIMBUSWARE_SANDBOX_K8S_EXEC_POD=  NIMBUSWARE_E2B_API_KEY=
# Agent risk caps: NIMBUSWARE_AGENT_MAX_TOOL_STEPS=20  NIMBUSWARE_AGENT_MAX_SHELL_INVOCATIONS=5  NIMBUSWARE_AGENT_MAX_WRITE_BYTES=262144
# Context efficiency: NIMBUSWARE_SLICE_BUDGET_PRESET=standard  NIMBUSWARE_READ_MAX_CHARS=16000  NIMBUSWARE_SHELL_OUTPUT_MAX_CHARS=4000
# NIMBUSWARE_AGENT_JIT_LOOP=1  NIMBUSWARE_AGENT_TOOLS=read,write,edit,grep,shell,browser_act  NIMBUSWARE_PROJECTION_PRUNE_AGENT_TOOLS=1
# NIMBUSWARE_AGENT_COMPACT=1  NIMBUSWARE_CAMPAIGN_COMPACT_ENABLED=1
# External chat webhook (not in-product workspace): NIMBUSWARE_WEBHOOK_SECRET=
# Fast slice / probation: NIMBUSWARE_FAST_SLICE=0  NIMBUSWARE_PROBATION_AUTO_SHELVE=1  NIMBUSWARE_PROBATION_NOTIFY_BEFORE_PROMOTE=1
# Micro-slice budget preset (Maker): NIMBUSWARE_SLICE_BUDGET_PRESET=standard  # tiny | standard | careful
# Slice context packet: NIMBUSWARE_SLICE_REPO_MAP_ENABLED=1
# Symbol sketch (Pyright LSP documentSymbol, AST fallback): NIMBUSWARE_SLICE_LSP_ENABLED=1
# NIMBUSWARE_SLICE_LSP_COMMAND=  NIMBUSWARE_SLICE_LSP_TIMEOUT_SEC=8
# Per-slice git commit after gate PASS (Maker Settings): NIMBUSWARE_SLICE_AUTO_COMMIT=0
# SWE-bench harness (scheduled): NIMBUSWARE_SWE_BENCH_ENABLED=1  NIMBUSWARE_SWE_BENCH_MANIFEST=
# NIMBUSWARE_SWE_BENCH_WRITE_JSON=0
# Optional slice browser verify (micro_slice): set slice.e2e.enabled: true in configs/workflows/micro_slice.yaml
# Install: poetry run playwright install  (or custom shell via NIMBUSWARE_SLICE_E2E_COMMAND)
# When Playwright/CLI is missing or tests/e2e is absent, slice.e2e reports SKIP (gate still passes)
# NIMBUSWARE_SLICE_E2E_COMMAND=
# Enterprise OIDC (Admin Console): NIMBUSWARE_OIDC_ENABLED=0  NIMBUSWARE_OIDC_ISSUER=  NIMBUSWARE_OIDC_CLIENT_ID=
# Enterprise audit export: NIMBUSWARE_AUDIT_RETENTION_DAYS=90
# Future event_store purge horizon (disabled when 0): NIMBUSWARE_EVENT_STORE_RETENTION_DAYS=365
NIMBUSWARE_DATABASE_URL=postgresql://nimbusware:nimbusware@127.0.0.1:5432/nimbusware

# Postgres superuser password from the installer wizard (install script prompts if wrong/missing).
# NIMBUSWARE_POSTGRES_SUPERPASSWORD=

PORT=8000
# Prefer NIMBUSWARE_API_PORT for API bind; PORT is a legacy alias read by env_flags.
# NIMBUSWARE_API_HOST=0.0.0.0
NIMBUSWARE_API_BASE=http://127.0.0.1:8000/v1

# Ollama base URL (optional): NIMBUSWARE_OLLAMA_BASE_URL=http://127.0.0.1:11434
# Legacy alias still read: OLLAMA_HOST=http://127.0.0.1:11434
# Installer profile (recommended | barebones): NIMBUSWARE_INSTALL_PROFILE=recommended
# Enable LLM stages when Ollama + models are ready: NIMBUSWARE_USE_LLM=1

# Hardware probe (dev/CI): NIMBUSWARE_HW_FIXTURE=weak|medium|strong
# Resource governor: NIMBUSWARE_MAX_SYSTEM_RAM_PCT=75  NIMBUSWARE_HW_AUTO_ADJUST=1
# Mid-run pressure: NIMBUSWARE_PRESSURE_DEGRADE_STUB=1 (default on; set 0 to keep LLM under RAM block)
# Memory index rebuild at run start is skipped when RAM use is at/above max_system_ram_pct (warn+)
# Enterprise SSH probe (optional): NIMBUSWARE_HW_SSH_HOST=  NIMBUSWARE_HW_SSH_IDENTITY=
# Fleet hardware tiers (API): NIMBUSWARE_HW_FLEET_HOSTS=host-a.example,host-b.example
# Dev mock SSH: NIMBUSWARE_HW_SSH_MOCK=1

# Secret for admin API routes; send header X-Nimbusware-Admin-Token: <value>
# Replace before production — search: nimbusware-dev-admin-token-SEARCH_AND_REPLACE_BEFORE_PROD
NIMBUSWARE_ADMIN_TOKEN=nimbusware-dev-admin-token-SEARCH_AND_REPLACE_BEFORE_PROD

# Enterprise Maker user key (maker_user scope). Individual edition: leave unset.
# NIMBUSWARE_API_KEY=

# Cross-console deep links (desktop defaults)
# NIMBUSWARE_MAKER_URL=http://127.0.0.1:8501
# NIMBUSWARE_ADMIN_CONSOLE_URL=http://127.0.0.1:8502
